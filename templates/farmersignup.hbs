<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/farmersignup.css">
<title>KONC Signup</title>


</head>

<body>

<!-- ===== SIGNUP ===== -->
<div class="signup-container">
<form class="signup-box" action="/farmersignup" method="post">
<h2>Create Account</h2>

<input type="text" name="name" placeholder="Full Name" required>
<input type="text" name="farmerId" placeholder="Farmer ID" required>
<input type="email" name="email" placeholder="Email" required>
<input type="password" name="password" placeholder="Password" required>
<input type="password" name="confirmPassword" placeholder="Confirm Password" required>

<button type="submit">Signup</button>

<p class="login-link">
Already have account? <a href="/farmerlogin">Login</a>
</p>
</form>
</div>

<footer class="footer">
<div class="footer-container">

    <div class="footer-box">

        <h3>Milk Accounting System</h3>

        <p>
            Complete dairy collection and
            accounting solution with
            Milk Analyzer and Weighing
            Machine integration.
        </p>

    </div>

    <div class="footer-box">

        <h3>Quick Links</h3>

        <a href="/">Home</a>
        <a href="/about">About Us</a>
        <a href="/contact">Contact Us</a>

    </div>

    <div class="footer-box">

        <h3>Portals</h3>

        <a href="/collectionagentlogin">
            Collection Agent Login
        </a>

        <a href="/farmerlogin">
            Farmer Login
        </a>

    </div>

    <div class="footer-box">

        <h3>Features</h3>

        <p>Milk Analyzer Integration</p>
        <p>Weighing Machine Integration</p>
        <p>Farmer Management</p>
        <p>Collection Reports</p>
        <p>Payment Tracking</p>

    </div>

</div>

<div class="footer-bottom">

    <p>
        © 2026 Milk Accounting System.
        All Rights Reserved.
    </p>

</div>
</footer>


</body>
</html>