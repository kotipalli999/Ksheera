<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Milk Accounting - Dashboard</title>
    <link rel="stylesheet" href="/collectionagentprofile.css">
    <!-- ఫాంట్ అవసమ్ ఐకాన్స్ కొరకు CDN లింక్ -->
    <link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <!-- 1. సైడ్‌బార్ ప్యానెల్ -->
    <div class="sidebar">
        <div class="logo">
            <h2>🥛 Ksheera Accounting</h2>
            <p>Collection Agent</p>
        </div>
        <div class="menu">
            <a href="/collectionagentdashboardmenu">📊 Dashboard</a>
            <a href="/agent/profile"  class="active">👤 Profile</a> <!-- లింక్ ఇక్కడ సరిచేయబడింది -->
            <a href="/agent/farmers">🚜 Farmers</a>
            <a href="/agent/collections">🥛 Milk Collection</a>
            <a href="/agent/farmer-ledger">📒 Farmers Ledger</a>
            <a href="/agent/payments">💰 Payment Reports</a>
            <a href="/agent/payment-transactions">📈 Payment Trasactions</a>
            <a href="">🖥️ Device Status</a>
            <a href="">⚙️ Settings</a>
            <a href="/logout" class="logout">🚪 Logout</a>
        </div>
    </div>

    <!-- 2. మెయిన్ కంటెంట్ డ్యాష్‌బోర్డ్ -->
    <div class="main-content"> <!-- లేఅవుట్ బగ్ రాకుండా ఇక్కడ క్లాస్ యాడ్ చేసాం -->
        
        <!-- 🌟 హెడర్ భాగం -->
        <header class="dashboard-header">
            <div class="header-title">
                <h1>📊 Today Milk Overview</h1>
                <p class="welcome-text">Welcome back, {{agent.name}}</p>
            </div>
            
            <div class="profile-card-horizontal">
                <div class="agent-avatar">
                    <img src="/image.jpeg"alt="Profile">
                    <span class="status-indicator {{agent.status}}"></span>
                </div>
                <div class="agent-info-grid">
                    <div class="info-row-top">
                        <span class="agent-name">{{agent.name}}</span>
                        <span class="badge center-badge"><i class="fa-solid fa-industry"></i> {{agent.centerName}}</span>
                    </div>
                    <div class="info-row-bottom">
                        <span class="info-item"><i class="fa-solid fa-id-card"></i> {{agent.agentId}}</span>
                        <span class="info-item"><i class="fa-solid fa-phone"></i> {{agent.mobile}}</span>
                        <span class="info-item"><i class="fa-solid fa-location-dot"></i> {{agent.village}}</span>
                    </div>
                </div>
            </div>
        </header>
            
        <!-- 📈 ప్రధాన గణాంకాల గ్రిడ్ (Stats Grid) -->
        <div class="stats-grid">
            <div class="stat-card total-milk">
                <div class="stat-info">
                    <h3>మొత్తం పాలు (Today Total Milk)</h3>
                    <p id="txtTotalMilk">{{totalMilk}} L</p>
                </div>
                <div class="stat-icon"><i class="fa-solid fa-tint"></i></div>
            </div>
            <div class="stat-card farmers">
                <div class="stat-info">
                    <h3>మొత్తం రైతులు (Today Total Farmers)</h3>
                    <p id="txtTotalFarmers">{{totalFarmers}}</p>
                </div>
                <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
            </div>
            <div class="stat-card amount">
                <div class="stat-info">
                    <h3>మొత్తం విలువ (Today Total Amount)</h3>
                    <p id="txtTotalAmount">₹ {{totalAmount}}</p>
                </div>
                <div class="stat-icon"><i class="fa-solid fa-indian-rupee-sign"></i></div>
            </div>
        </div>

        <!-- 🌅 🌌 సెషన్ వైజ్ బ్రేక్‌డౌన్ (Morning vs Evening) -->
        <div class="session-container">
            <!-- ఉదయం సెషన్ కార్డ్ -->
            <div class="session-card">
                <h3 class="session-title morning">
                    <i class="fa-solid fa-sun"></i>
                    Morning Session (ఉదయం)
                </h3>
                <div class="session-data">
                    <span>మొత్తం పాలు (Milk):</span>
                    <span id="lblMorningMilk">{{morningMilk}} L</span>
                </div>
                <div class="session-data">
                    <span>మొత్తం రైతులు (Farmers):</span>
                    <span id="lblMorningFarmers">{{morningFarmers}}</span>
                </div>
                <div class="session-data">
                    <span>మొత్తం విలువ (Amount):</span>
                    <span id="lblMorningAmount">₹ {{morningAmount}}</span>
                </div>
            </div>

            <!-- సాయంత్రం సెషన్ కార్డ్ -->
            <div class="session-card">
                <h3 class="session-title evening">
                    <i class="fa-solid fa-moon"></i>
                    Evening Session (సాయంత్రం)
                </h3>
                <div class="session-data">
                    <span>మొత్తం పాలు (Milk):</span>
                    <span id="lblEveningMilk">{{eveningMilk}} L</span>
                </div>
                <div class="session-data">
                    <span>మొత్తం రైతులు (Farmers):</span>
                    <span id="lblEveningFarmers">{{eveningFarmers}}</span>
                </div>
                <div class="session-data">
                    <span>మొత్తం విలువ (Amount):</span>
                    <span id="lblEveningAmount">₹ {{eveningAmount}}</span>
                </div>
            </div>
        </div>

    </div>
    <script>
async function loadTodayStats() {
    try {
        const today = new Date()
            .toISOString()
            .split("T")[0];

        const response = await fetch(
            `/api/dashboard-stats?fromDate=${today}&toDate=${today}`
        );

        const data = await response.json();

        if (!data.success) return;

        const stats = data.stats;
        document.getElementById("txtTotalFarmers")
    .textContent =
    stats.totalFarmers || 0;


        document.getElementById("txtTotalMilk")
            .textContent =
            (stats.totalMilk || 0).toFixed(2) + " L";

        document.getElementById("txtTotalAmount")
            .textContent =
            "₹ " +
            (stats.totalAmount || 0).toFixed(2);

        document.getElementById("lblMorningMilk")
            .textContent =
            (stats.morningMilk || 0).toFixed(2) + " L";

        document.getElementById("lblMorningAmount")
            .textContent =
            "₹ " +
            (stats.morningAmount || 0).toFixed(2);

        document.getElementById("lblMorningFarmers")
            .textContent =
            stats.morningFarmers || 0;

        document.getElementById("lblEveningMilk")
            .textContent =
            (stats.eveningMilk || 0).toFixed(2) + " L";

        document.getElementById("lblEveningAmount")
            .textContent =
            "₹ " +
            (stats.eveningAmount || 0).toFixed(2);

        document.getElementById("lblEveningFarmers")
            .textContent =
            stats.eveningFarmers || 0;

    } catch (err) {
        console.error(
            "Failed to load today's dashboard stats:",
            err
        );
    }
}

document.addEventListener(
    "DOMContentLoaded",
    loadTodayStats
);
</script>
</body>
</html>
