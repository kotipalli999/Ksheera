<!-- మీ JavaScript ఫైల్‌ను ఇక్కడ లింక్ చేయండి -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

    // 1. About Us navbar click → smooth scroll
    var aboutBtn = document.getElementById("aboutBtn");
    if (aboutBtn) {
        aboutBtn.addEventListener("click", function (e) {
            e.preventDefault();
            var aboutSection = document.getElementById("about-section");
            if (aboutSection) {
                aboutSection.scrollIntoView({
                    behavior: "smooth",
                    block: "start"
                });
            }
        });
    }

    // 2. FIXED: Contact Us navbar click → smooth scroll (కొత్తగా జోడించబడింది)
    var contactBtn = document.getElementById("contactBtn");
    if (contactBtn) {
        contactBtn.addEventListener("click", function (e) {
            e.preventDefault();
            var contactSection = document.getElementById("contact-section");
            if (contactSection) {
                contactSection.scrollIntoView({
                    behavior: "smooth",
                    block: "start"
                });
            }
        });
    }

    // 3. Footer Links (About & Contact) → smooth scroll
    // href లో # ఉన్న అన్ని లింకులను ఆటోమేటిక్‌గా స్మూత్ స్క్రోల్ చేస్తుంది
    var footerLinks = document.querySelectorAll('a[href^="#"]');
    footerLinks.forEach(function (link) {
        link.addEventListener("click", function (e) {
            e.preventDefault();
            var targetId = this.getAttribute("href");
            var targetSection = document.getElementById(targetId.replace("#", ""));
            if (targetSection) {
                targetSection.scrollIntoView({
                    behavior: "smooth",
                    block: "start"
                });
            }
        });
    });

    // 4. Scroll animation - rows fade in when visible
    var rows = document.querySelectorAll(".about-row");
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15 });

    rows.forEach(function (row) {
        observer.observe(row);
    });
    
    // 5. Mobile Menu Toggle
    const menuToggle = document.getElementById('menuToggle');
    const navLinks = document.getElementById('navLinks');

    if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
            menuToggle.classList.toggle('active');
        });
    }

        // 6. Web3Forms Form Submission Message
    const form = document.getElementById('form');
    if (form) {
        const submitBtn = form.querySelector('button[type="submit"]');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            
            // FIXED: append కి బదులుగా set వాడుతున్నాము మరియు కీ చివర స్పేస్‌లు లేకుండా .trim() చేసాము
            const cleanKey = "8b8322f5-a5c6-46f3-ba7d-50454871c0a8".trim();
            formData.set("access_key", cleanKey);

            const originalText = submitBtn.textContent;
            submitBtn.textContent = "Sending...";
            submitBtn.disabled = true;

            try {
                const response = await fetch("https://api.web3forms.com/submit", {
                    method: "POST",
                    body: formData
                });

                const data = await response.json();

                // FIXED: response.ok తో పాటు data.success కూడా ట్రూ అయిందో లేదో చూస్తున్నాము
                if (response.ok && data.success) {
                    alert("Success! Your message has been sent.");
                    form.reset();
                } else {
                    alert("Error: " + (data.message || "Submission failed. Please check Access Key."));
                }

            } catch (error) {
                alert("Something went wrong. Please try again.");
            } finally {
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        });
    }

}); // DOMContentLoaded ఇక్కడితో ముగుస్తుంది

</script>
