<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Milk Accounting - Farmers Ledger</title>
    <!-- డ్యాష్‌బోర్డ్ CSS లింక్ -->
    <link rel="stylesheet" href="/farmerledger.css">
    <!-- ఫాంట్ అవసమ్ ఐకాన్స్ (FontAwesome) -->
    <link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">   
</head>
<body>

    <!-- 1. సైడ్‌బార్ ప్యానెల్ -->
    <div class="sidebar">
        <div class="logo">
            <h2>🥛 Ksheera Accounting</h2>
            <p>Collection Agent</p>
        </div>
        <div class="menu">
            <a href="/collectionagentdashboardmenu">📊 Dashboard</a>
            <a href="/agent/profile">👤 Profile</a>
            <a href="/agent/farmers">🚜 Farmers</a>
            <a href="/agent/collections">🥛 Milk Collection</a>
            <a href="/agent/farmer-ledger" class="active">📒 Farmers Ledger</a>
            <a href="/agent/payments">💰 Payment Reports</a>
            <a href="/agent/payment-transactions">📈 Patment Transactions</a>
            <a href="">🖥️ Device Status</a>
            <a href="">⚙️ Settings</a>
            <a href="/logout" class="logout">🚪 Logout</a>
        </div>
    </div>

    <!-- 2. మెయిన్ కంటెంట్ -->
    <div class="main-content">
        
        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 1px solid #e2e8f0; padding-bottom: 15px;">
            <h1>📒 Farmer Ledger Account</h1>
            
            <div class="agent-welcome-badge" style="text-align: right; background: #FEFCE8; padding: 8px 15px; border-radius: 10px; border: 1px solid #E2E8F0;">
                <span style="font-size: 14px; font-weight: 600; color: #15803D; display: block;">👤 {{agent.name}}</span>
                <span style="font-size: 11px; color: #64748B; display: block; margin-top: 2px;">🏢 {{agent.centerName}}</span>
            </div>
        </header>

        <!-- సెర్చ్ మరియు డేట్ ఫిల్టర్ సెక్షన్ -->
        <div class="search-filter-section">
            <div class="form-group">
                <label for="searchFarmer">Search Farmer (ID / Name):</label>
                <input type="text" id="searchFarmer" list="farmerList" placeholder="e.g., FRM0001 లేదా రాము">
                <datalist id="farmerList">
    {{#each farmers}}
        <option value="{{this.farmerId}}">
            {{this.farmerId}} - {{this.name}}
        </option>

        <option value="{{this.name}}">
            {{this.farmerId}} - {{this.name}}
        </option>
    {{/each}}
</datalist>
            </div>
            <div class="form-group">
                <label for="fromDate">From Date:</label>
                <input type="date" id="fromDate">
            </div>
            <div class="form-group">
                <label for="toDate">To Date:</label>
                <input type="date" id="toDate">
            </div>
            <div class="btn-actions">
                <button class="action-btn btn-search" onclick="fetchLedgerData()"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
                <button class="action-btn btn-print" onclick="window.print()"><i class="fa-solid fa-print"></i> Print</button>
                <button class="action-btn btn-pdf" onclick="downloadPDF()"><i class="fa-solid fa-file-pdf"></i> PDF</button>
            </div>
        </div>

        <!-- ప్రధాన లెడ్జర్ కంటెంట్ కంటైనర్ -->
       <!-- 👤 Farmer Profile Card -->
       <div class="ledger-container" id="printableLedger">
<div class="farmer-profile-card">

    <div class="profile-item">
        <span>రైతు కోడ్ / పేరు (Farmer Code & Name)</span>
        <strong id="farmerName">
            {{#if farmer}}
                {{farmer.farmerId}} - {{farmer.name}}
            {{else}}
                Select a Farmer
            {{/if}}
        </strong>
    </div>

    <div class="profile-item">
        <span>ఫోన్ నంబర్ (Phone Number)</span>
        <strong id="farmerMobile">
            {{#if farmer}}
                {{farmer.mobile}}
            {{else}}
                -
            {{/if}}
        </strong>
    </div>

    <div class="profile-item">
        <span>పాలు రకం (Milk Type)</span>
        <strong>
            <span id="farmerMilkType" class="badge badge-cow">
                {{#if farmer}}
                    {{farmer.preferredMilkType}}
                {{else}}
                    -
                {{/if}}
            </span>
        </strong>
    </div>

    <div class="profile-item">
        <span>బ్యాంక్ ఖాతా (Bank A/c)</span>
        <strong id="farmerBank">
            {{#if farmer.bankAccount}}
                {{farmer.bankAccount}}
            {{else}}
                Not Added
            {{/if}}
        </strong>
    </div>

</div>

            <!-- 📊 లెడ్జర్ సమ్మరీ బాక్సులు (Ledger Summary) -->
            <div class="summary-grid">
                <div class="summary-card milk">
                    <h4>మొత్తం లీటర్లు (Total Liters)</h4>
                    <p id="sumLiters">{{summary.totalLiters}} L</p>
                </div>
                <div class="summary-card amount">
                    <h4>పాల మొత్తం విలువ (Gross Amount)</h4>
                    <p id="sumGross">₹ {{summary.grossAmount}}</p>
                </div>
                <div class="summary-card advance">
                    <h4>అడ్వాన్స్ / డిడక్షన్స్ (Advance/Deductions)</h4>
                    <p id="sumAdvance" style="color: #d97706;">₹ {{summary.totalAdvance}}</p>
                </div>
                <div class="summary-card amount">
                    <h4>చెల్లించిన మొత్తం (Paid Amount)</h4>
                    <p id="sumPaid" style="color: #059669;">₹ {{summary.paidAmount}}</p>
                </div>
                <div class="summary-card balance">
                    <h4>నికర నిల్వ బ్యాలెన్స్ (Net Balance Due)</h4>
                                        <p id="sumBalance" style="color: #dc2626;">₹ {{summary.netBalance}}</p>
                </div>
            </div>

            <!-- 📒 లెడ్జర్ డేటా టేబుల్ (Ledger Table) -->
            <div class="table-responsive">
                <table class="ledger-table">
                    <thead>
                        <tr>
                            <th>తేదీ (Date)</th>
                            <th>సెషన్</th>
                            <th>రకం (Type)</th>
                            <th>లీటర్లు (Liters)</th>
                            <th>FAT / SNF</th>
                            <th>ధర (Rate)</th>
                            <th>మొత్తం (Gross)</th>
                            <th>అడ్వాన్స్ కట్</th>
                            <th>చెల్లింపు (Paid)</th>
                            <th>బ్యాలెన్స్</th>
                        </tr>
                    </thead>
                    <tbody id="ledgerTableBody">
                        <!-- సర్వర్ సైడ్ రెండరింగ్ (Handlebars/EJS) లేదా క్లయింట్ స్క్రిప్ట్ కోసం లూప్ స్ట్రక్చర్ -->
                        {{#if ledgerEntries}}
                            {{#each ledgerEntries}}
                            <tr>
                                <td>{{this.collectionDate}}</td>
                                <td>
                                    <span class="badge {{#if (eq this.session "Morning")}}badge-morning{{else}}badge-evening{{/if}}">
                                     {{this.session}}
                                    </span>
                                </td>
                                <td>
                                    <span class="badge {{#if (eq this.milkType "Cow")}}badge-cow{{else}}badge-buff{{/if}}">
                                        {{this.milkType}}
                                    </span>
                                </td>
                                <td>{{this.liters}} L</td>
                                <td>{{this.fat}} / {{this.snf}}</td>
                                <td>₹ {{this.rate}}</td>
                                <td><strong>₹ {{this.totalAmount}}</strong></td>
                                <td style="color: #d97706;">- ₹ {{this.advanceAdjusted}}</td>
                                <td style="color: #059669;">₹ {{this.paidAmount}}</td>
                                <td style="font-weight: bold; color: #dc2626;">₹ {{this.balance}}</td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <!-- లోకల్ అజాక్స్ సెర్చ్ లేదా డేటా లేనప్పుడు చూపే రో -->
                            <tr id="noDataRow">
                                <td colspan="10" style="text-align: center; color: #64748b; padding: 25px;">
                                    దయచేసి పైన రైతు ID/పేరు మరియు తేదీలను నమోదు చేసి సెర్చ్ బటన్ క్లిక్ చేయండి.
                                </td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>

            <!-- 🌅 🌌 సెషన్ వైజ్ బ్రేక్‌డౌన్ (Morning/Evening Sub-Totals) -->
            <div class="session-subtotals" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 25px;">
                <!-- మోర్నింగ్ సెషన్ టోటల్స్ -->
                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <h5 style="margin: 0 0 10px 0; color: #d97706; font-size: 14px;"><i class="fa-solid fa-sun"></i> Morning Session Totals</h5>
                    <div style="display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px; color: #475569;">
                        <span>మొత్తం పాలు (Milk):</span> <strong id="subMorningMilk">{{summary.morningMilk}} L</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 13px; color: #475569;">
                        <span>మొత్తం విలువ (Amount):</span> <strong id="subMorningAmount">₹ {{summary.morningAmount}}</strong>
                    </div>
                </div>
                <!-- ఈవెనింగ్ సెషన్ టోటల్స్ -->
                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <h5 style="margin: 0 0 10px 0; color: #0369a1; font-size: 14px;"><i class="fa-solid fa-moon"></i> Evening Session Totals</h5>
                    <div style="display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px; color: #475569;">
                        <span>మొత్తం పాలు (Milk):</span> <strong id="subEveningMilk">{{summary.eveningMilk}} L</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 13px; color: #475569;">
                        <span>మొత్తం విలువ (Amount):</span> <strong id="subEveningAmount">₹ {{summary.eveningAmount}}</strong>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
    <!-- 🛠️ PDF జనరేషన్ కొరకు క్లయింట్ సైడ్ లైబ్రరీ CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.3/html2pdf.bundle.min.js"></script>
    
    <script>
        // డ్యాష్‌బోర్డ్ ఓపెన్ అవ్వగానే డెమో కోసం డిఫాల్ట్ తేదీలను సెట్ చేయడం
        document.addEventListener("DOMContentLoaded", () => {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('toDate').value = today;
            
            const pastDate = new Date();
            pastDate.setDate(pastDate.getDate() - 10); // గత 10 రోజుల రిపోర్ట్ డిఫాల్ట్
            document.getElementById('fromDate').value = pastDate.toISOString().split('T')[0];
        });

        async function fetchLedgerData() {
    const searchInput =
        document.getElementById("searchFarmer")
            .value.trim();

    const fromDate =
        document.getElementById("fromDate")
            .value;

    const toDate =
        document.getElementById("toDate")
            .value;

    if (!searchInput) {
        alert(
            "దయచేసి రైతు కోడ్ (FRM0001) లేదా పేరు నమోదు చేయండి."
        );
        return;
    }

    try {
        const response =
            await fetch(
                `/api/farmer-ledger?farmer=${encodeURIComponent(searchInput)}&fromDate=${fromDate}&toDate=${toDate}`
            );

        const data =
            await response.json();

        if (!data.success) {
            alert(data.message);
            return;
        }
        document.getElementById(
    "farmerName"
).innerText =
    `${data.farmer.farmerId} - ${data.farmer.name}`;

document.getElementById(
    "farmerMobile"
).innerText =
    data.farmer.mobile || "-";

document.getElementById(
    "farmerMilkType"
).innerText =
    data.farmer.preferredMilkType || "-";

document.getElementById(
    "farmerBank"
).innerText =
    data.farmer.bankAccount ||
    "Not Added";

        document.getElementById(
            "sumLiters"
        ).innerText =
            data.summary.totalLiters +
            " L";

        document.getElementById(
            "sumGross"
        ).innerText =
            "₹ " +
            data.summary.grossAmount;

        document.getElementById(
            "sumAdvance"
        ).innerText =
            "₹ " +
            data.summary.totalAdvance;

        document.getElementById(
            "sumPaid"
        ).innerText =
            "₹ " +
            data.summary.paidAmount;

        document.getElementById(
            "sumBalance"
        ).innerText =
            "₹ " +
            data.summary.netBalance;

        document.getElementById(
            "subMorningMilk"
        ).innerText =
            data.summary.morningMilk +
            " L";

        document.getElementById(
            "subMorningAmount"
        ).innerText =
            "₹ " +
            data.summary.morningAmount;

        document.getElementById(
            "subEveningMilk"
        ).innerText =
            data.summary.eveningMilk +
            " L";

        document.getElementById(
            "subEveningAmount"
        ).innerText =
            "₹ " +
            data.summary.eveningAmount;

        const tbody =
            document.getElementById(
                "ledgerTableBody"
            );

        tbody.innerHTML = "";

        data.ledgerEntries.forEach(
            item => {
                tbody.innerHTML += `
                    <tr>
                        <td>${new Date(item.collectionDate).toLocaleDateString()}</td>
                        <td>${item.session}</td>
                        <td>${item.milkType}</td>
                        <td>${item.liters} L</td>
                        <td>${item.fat} / ${item.snf}</td>
                        <td>₹ ${item.rate}</td>
                        <td>₹ ${item.totalAmount}</td>
                        <td>₹ ${item.advanceAdjusted || 0}</td>
                        <td>₹ ${item.paidAmount || 0}</td>
                        <td>₹ ${item.balance || item.totalAmount}</td>
                    </tr>
                `;
            }
        );

    } catch (error) {
        console.error(
            "డేటా లోడ్ చేయడంలో లోపం సంభవించింది:",
            error
        );
    }
}
        // 📄 క్లియర్ ల్యాండ్‌స్కేప్ ప్రింట్ వ్యూతో PDF డౌన్‌లోడ్ ఫంక్షన్//
        /*pdf generation js script*/
        function downloadPDF() {

    const farmer =
        document.getElementById(
            "searchFarmer"
        ).value || "Farmer";

    const fromDate =
        document.getElementById(
            "fromDate"
        ).value || "All";

    const toDate =
        document.getElementById(
            "toDate"
        ).value || "All";

    const element =
        document.getElementById(
            "printableLedger"
        );

    if (!element) {
        alert(
            "Ledger content not found."
        );
        return;
    }

    const options = {
        margin: 10,
        filename:
            `Ledger_${farmer}_${fromDate}_to_${toDate}.pdf`,
        image: {
            type: "jpeg",
            quality: 0.98
        },
        html2canvas: {
            scale: 3,
            useCORS: true
        },
        jsPDF: {
            unit: "mm",
            format: "a4",
            orientation: "landscape"
        },
        pagebreak: {
            mode: [
                "avoid-all",
                "css",
                "legacy"
            ]
        }
    };

    html2pdf()
        .set(options)
        .from(element)
        .save();
}

    </script>
    </body>
</html>

